<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users List</title>
</head>
<body>
<h1>Our Current Users</h1>
<table>
    <tr>
        <th>First Name</th>
        <th>Last Name</th>
    </tr>
    <% let users = locals.users;
    for(let i = 0; i < users.length; i++){ %>
    <tr>
        <td><a href="/users/<%= i %>"><%= users[i].firstName %></a></td>
        <td><%= users[i].lastName %></td>
    </tr>
    <% } %>
</table>
</body>
</html>